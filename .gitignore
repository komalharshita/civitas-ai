# ─────────────────────────────────────────────────────────────
#  Civitas AI — .gitignore
#  Everything listed here is excluded from version control.
# ─────────────────────────────────────────────────────────────


# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# ── Build output ──────────────────────────────────────────────
dist/
dist-ssr/
build/
.vite/
*.local


# ══════════════════════════════════════════════════════════════
#  🔐 SECRETS — NEVER COMMIT THESE
# ══════════════════════════════════════════════════════════════

# Environment files (contain Firebase keys and API keys)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# Firebase Admin service account key (grants full DB access)
scripts/serviceAccountKey.json
serviceAccountKey.json
*serviceAccount*.json

# Google Cloud credentials
gcloud-credentials.json
*.credentials.json


# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
firebase-debug.log
firestore-debug.log
hosting-debug.log
database-debug.log


# ── Testing artifacts ─────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/


# ── Cache ─────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.prettiercache


# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo


# ── Firebase ──────────────────────────────────────────────────
.firebase/
.firebaserc.local


# ── Editor: VS Code ──────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
*.code-workspace


# ── Editor: JetBrains (WebStorm, IntelliJ) ───────────────────
.idea/
*.iml
*.iws
*.ipr
out/


# ── Editor: Vim / Emacs ───────────────────────────────────────
*.swp
*.swo
*.swn
*~
.#*
\#*#


# ── Editor: Sublime Text ─────────────────────────────────────
*.sublime-project
*.sublime-workspace


# ── OS: macOS ────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon


# ── OS: Windows ───────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk


# ── OS: Linux ────────────────────────────────────────────────
.fuse_hidden*
.directory
.Trash-*
.nfs*


# ── Misc ──────────────────────────────────────────────────────
*.pem
*.p12
*.key
*.cert
*.crt
.netlify/
vercel/
.vercel/
