# ═══════════════════════════════════════════════════════════════════════
#  Civitas AI — Environment Variables
#
#  HOW TO USE:
#    cp .env.example .env
#    Fill in your real values below
#    Restart the dev server: npm run dev
#
#  ⚠️  NEVER commit .env to git — it contains secret API keys
#  ⚠️  All variables MUST start with VITE_ (required by Vite)
# ═══════════════════════════════════════════════════════════════════════


# ── Firebase Configuration ─────────────────────────────────────────────
#
#  WHERE TO FIND THESE:
#    1. Go to https://console.firebase.google.com
#    2. Select your project
#    3. Click the gear icon → Project Settings
#    4. Scroll to "Your apps" → click your web app
#    5. Copy values from the firebaseConfig object
#
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=


# ── Google Gemini API Key ──────────────────────────────────────────────
#
#  WHERE TO FIND THIS:
#    1. Go to https://aistudio.google.com/app/apikey
#    2. Sign in with your Google account
#    3. Click "Create API key"
#    4. Copy the generated key (starts with "AIzaSy...")
#
#  FREE TIER LIMITS:
#    - 15 requests per minute
#    - 1,000,000 tokens per day
#    - No billing required for development
#
VITE_GEMINI_API_KEY=


# ── Optional: Vertex AI via Google Cloud Platform ─────────────────────
#
#  For production deployments using GCP service accounts.
#  Leave these empty for the hackathon — use VITE_GEMINI_API_KEY above.
#
#  WHERE TO FIND THESE:
#    1. Go to https://console.cloud.google.com
#    2. Create/select a project
#    3. Enable Vertex AI API
#    4. Generate a service account key (use in backend ONLY)
#
# VITE_GCP_PROJECT_ID=
# VITE_GCP_LOCATION=us-central1
# VITE_VERTEX_AI_TOKEN=
