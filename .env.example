# ─────────────────────────────────────────────────────────────
#  Civitas AI — Environment Variables
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your real values below
#  3. NEVER commit .env to git — it's already in .gitignore
# ─────────────────────────────────────────────────────────────

# ── Firebase (get from Firebase Console → Project Settings → Your Apps) ──
VITE_FIREBASE_API_KEY=AIzaSy_YOUR_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ── Google Gemini API (get from https://aistudio.google.com/app/apikey) ──
# This is the simplest key for hackathon — works with Gemini 1.5 Flash
VITE_GEMINI_API_KEY=AIzaSy_YOUR_GEMINI_KEY_HERE

# ── Optional: Vertex AI via GCP (use instead of Gemini key for production) ──
# VITE_GCP_PROJECT_ID=your-gcp-project-id
# VITE_GCP_LOCATION=us-central1
# VITE_VERTEX_AI_TOKEN=your-oauth2-token   ← rotate this; use service account in prod
